 fn test_mutex_arc_condvar() {
 let packet = Packet(Arc::new((Mutex::new(false), Condvar::new())));
 let packet2 = Packet(packet.0.clone());
 let _ = channel();
 let _t = thread::spawn(move | | { rx.recv().unwrap(); let(lock, cvar) = &*packet2.0; let mut lock = lock.lock(); *lock = true; cvar.notify_one(); });
 let _ = &*packet.0;
 let mut lock = lock.lock();
 tx.send(()).unwrap();
 assert!(!*lock);
 while ! *lock { cvar.wait(&mut lock); }
 }
 
